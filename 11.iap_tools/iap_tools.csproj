    selected_btn = btn

    # 更新标题和描述
    lbl_cmd_title.config(text=f"{cmd_def['name']}  (0x{cmd_def['cmd']:02X})")
    lbl_cmd_desc.config(text=cmd_def.get("desc", ""))

    # 清空旧输入
    for w in param_inputs_frame.winfo_children():
        w.destroy()
    entry_widgets.clear()

    fields = cmd_def.get("fields", [])
    if fields:
        for i, f in enumerate(fields):
            tk.Label(param_inputs_frame, text=f["label"] + "：",
                     bg=CARD, font=UI, width=16, anchor=tk.W).grid(
                row=i, column=0, sticky=tk.W, pady=4)
            e = tk.Entry(param_inputs_frame, font=("Consolas", 13),
                         width=12, relief=tk.SOLID, bd=1, justify=tk.CENTER)
            e.insert(0, f["default"])
            e.grid(row=i, column=1, sticky=tk.W, padx=8, pady=4)
            entry_widgets[f["key"]] = e
        btn_generate.config(state=tk.NORMAL)
    else:
        tk.Label(param_inputs_frame, text="此命令无需参数，直接点击生成。",
                 bg=CARD, font=UI_SM, fg="#aaa").pack(anchor=tk.W)
        btn_generate.config(state=tk.NORMAL)

    # 清空结果
    clear_results()

