# ── 帧生成逻辑 ────────────────────────────────────────────────────────────────
def build_frames(cmd_def, values):
    """返回 [(描述, 字节列表), ...]"""
    t = cmd_def["type"]

    if t == "simple":
        return [(cmd_def["name"], [0x00, cmd_def["cmd"], 0x00, 0x00, 0x00, 0x00, 0x00, 0x00])]

    elif t == "16bit":
        val = int(float(values["temp"])) & 0xFFFF
        lo, hi = val & 0xFF, (val >> 8) & 0xFF
        return [(cmd_def["name"], [0x00, cmd_def["cmd"], lo, hi, 0x00, 0x00, 0x00, 0x00])]

    elif t == "16bit_crc":
        val = int(float(values["temp"])) & 0xFFFF
        lo, hi = val & 0xFF, (val >> 8) & 0xFF
        crc_data = [cmd_def["cmd"], lo, hi]
        crc = crc8(crc_data)
        return [(cmd_def["name"], [0x00, cmd_def["cmd"], lo, hi, crc, 0x00, 0x00, 0x00])]

    elif t == "calibration":
        factor = int(float(values["input_v"])  * 1000) & 0xFFFF
        theor  = int(float(values["target_v"]) * 1000) & 0xFFFF
        f_lo, f_hi = factor & 0xFF, (factor >> 8) & 0xFF
        t_lo, t_hi = theor  & 0xFF, (theor  >> 8) & 0xFF
        crc_data = [0x24, f_lo, f_hi, 0x00, 0x00, t_lo, t_hi, 0x00, 0x00]
        crc = crc8(crc_data)
        return [
            ("① CMD_FACTOR_VOLTAGE  0x22", [0x00, 0x22, f_lo, f_hi, 0x00, 0x00, 0x00, 0x00]),
            ("② CMD_THEOR_VOLTAGE   0x23", [0x00, 0x23, t_lo, t_hi, 0x00, 0x00, 0x00, 0x00]),
            ("③ CMD_VOLTAGE_CRC     0x24", [0x00, 0x24, crc,  0x00, 0x00, 0x00, 0x00, 0x00]),
            ("④ CMD_STORE_FLASH     0x11", [0x00, 0x11, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]),
        ]

    return []

def fmt(b): return f"{b:02X}"
def frame_str(bs): return "  ".join(fmt(b) for b in bs)

